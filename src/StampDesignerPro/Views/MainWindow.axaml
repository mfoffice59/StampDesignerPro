<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StampDesignerPro.Views.MainWindow"
        Title="Stamp Designer Pro"
        Width="1500"
        Height="940"
        MinWidth="1100"
        MinHeight="720"
        Background="#F2F6FB">
  <Grid ColumnDefinitions="540,*">
    <ScrollViewer Grid.Column="0" Padding="14">
      <StackPanel Spacing="10">

        <Border Background="#FFFFFF" BorderBrush="#D7E2F0" BorderThickness="1" CornerRadius="10" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="Stamp Designer Pro" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="Редактор круглых печатей" Foreground="#5D6B7C" />

            <TextBlock Text="Основные параметры" FontSize="16" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBlock Text="Стиль внешнего кольца" />
            <ComboBox Name="OuterStyleBox" SelectedIndex="0">
              <ComboBoxItem Content="Двойной круг" />
              <ComboBoxItem Content="Синяя полоса" />
            </ComboBox>

            <TextBlock Text="Цвет HEX" />
            <TextBox Name="ColorBox" Text="#003f9e" />

            <CheckBox Name="TransparentBox" Content="Прозрачный фон" IsChecked="True" />
          </StackPanel>
        </Border>

        <Border Background="#FFFFFF" BorderBrush="#D7E2F0" BorderThickness="1" CornerRadius="10" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="Текст" FontSize="16" FontWeight="Bold" Margin="0,0,0,4" />

            <TextBlock Text="Верхний текст" />
            <TextBox Name="TopTextBox" Text="«Sizning nomingiz» mas’uliyati cheklangan jamiyati" />

            <TextBlock Text="Нижний текст" />
            <TextBox Name="BottomTextBox" Text="O‘zbekiston Respublikasi - Toshkent shahri" />

            <TextBlock Text="Внутренний текст" />
            <TextBox Name="InnerTextBox" Text="STIR 000000000" />

            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,4,0">
                <TextBlock Text="Размер текста" />
                <TextBox Name="FontSizeBox" Text="27" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0">
                <TextBlock Text="Интервал букв" />
                <TextBox Name="LetterSpacingBox" Text="2" />
              </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,4,0">
                <TextBlock Text="Радиус текста" />
                <TextBox Name="TextRadiusBox" Text="285" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0">
                <TextBlock Text="Размер внутр. текста" />
                <TextBox Name="InnerFontSizeBox" Text="25" />
              </StackPanel>
            </Grid>

            <TextBlock Text="Радиус внутреннего текста" />
            <TextBox Name="InnerTextRadiusBox" Text="202" />
          </StackPanel>
        </Border>

        <Border Background="#FFFFFF" BorderBrush="#D7E2F0" BorderThickness="1" CornerRadius="10" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="Окружности и синяя полоса" FontSize="16" FontWeight="Bold" Margin="0,0,0,4" />

            <TextBlock Text="Текст синей полосы" />
            <TextBox Name="BandTextBox" Text="O‘ZBEKISTON RESPUBLIKASI - MChJ «SIZNING NOMINGIZ»" />

            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,4,0">
                <TextBlock Text="Внешний радиус" />
                <TextBox Name="OuterRadiusBox" Text="345" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0">
                <TextBlock Text="Второй радиус" />
                <TextBox Name="SecondRadiusBox" Text="323" />
              </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,4,0">
                <TextBlock Text="Внутренний радиус" />
                <TextBox Name="InnerRadiusBox" Text="232" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0">
                <TextBlock Text="Толщина линий" />
                <TextBox Name="LineWidthBox" Text="5" />
              </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,4,0">
                <TextBlock Text="Ширина полосы" />
                <TextBox Name="BandWidthBox" Text="54" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0">
                <TextBlock Text="Радиус полосы" />
                <TextBox Name="BandRadiusBox" Text="333" />
              </StackPanel>
            </Grid>

            <TextBlock Text="Размер текста полосы" />
            <TextBox Name="BandFontSizeBox" Text="25" />
          </StackPanel>
        </Border>

        <Border Background="#FFFFFF" BorderBrush="#D7E2F0" BorderThickness="1" CornerRadius="10" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="Логотип" FontSize="16" FontWeight="Bold" Margin="0,0,0,4" />

            <Grid ColumnDefinitions="*,*">
              <Button Grid.Column="0" Name="LoadLogoButton" Content="Загрузить логотип" Margin="0,0,4,0" />
              <Button Grid.Column="1" Name="DeleteLogoButton" Content="Удалить логотип" Margin="4,0,0,0" />
            </Grid>

            <Button Name="CenterLogoButton" Content="Логотип в центр" />

            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,4,0">
                <TextBlock Text="X" />
                <TextBox Name="LogoXBox" Text="0" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0">
                <TextBlock Text="Y" />
                <TextBox Name="LogoYBox" Text="25" />
              </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,4,0">
                <TextBlock Text="Размер" />
                <TextBox Name="LogoSizeBox" Text="170" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0">
                <TextBlock Text="Прозрачность" />
                <TextBox Name="LogoOpacityBox" Text="100" />
              </StackPanel>
            </Grid>

            <TextBlock Text="Перемещение - мышью по логотипу. Размер - колесом на холсте." Foreground="#5D6B7C" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Background="#FFFFFF" BorderBrush="#D7E2F0" BorderThickness="1" CornerRadius="10" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="Ластик" FontSize="16" FontWeight="Bold" Margin="0,0,0,4" />

            <CheckBox Name="EraserModeBox" Content="Включить ластик" />

            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,4,0">
                <TextBlock Text="Размер" />
                <TextBox Name="EraserSizeBox" Text="32" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,0,0">
                <TextBlock Text="Непрозрачность" />
                <TextBox Name="EraserOpacityBox" Text="100" />
              </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="*,*">
              <Button Grid.Column="0" Name="UndoEraserButton" Content="Назад" Margin="0,0,4,0" />
              <Button Grid.Column="1" Name="ClearEraserButton" Content="Очистить" Margin="4,0,0,0" />
            </Grid>

            <TextBlock Text="ЛКМ и вести - стирать. Колесо - размер." Foreground="#5D6B7C" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <Border Grid.Column="1" Background="#DDE8F4" Padding="22">
      <Border Background="White" CornerRadius="14" BorderBrush="#B8C8DD" BorderThickness="1">
        <Panel Name="CanvasHost" Background="White" />
      </Border>
    </Border>
  </Grid>
</Window>
