<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="StampDesignerPro.App">
  <Application.Styles>
    <FluentTheme />

    <Style Selector="Button">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Background" Value="#F7FAFF" />
      <Setter Property="BorderBrush" Value="#9CB7E8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#12325C" />
    </Style>

    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="#EAF2FF" />
      <Setter Property="BorderBrush" Value="#5F8FE8" />
    </Style>

    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="#D8E8FF" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="7,4" />
      <Setter Property="CornerRadius" Value="5" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="CornerRadius" Value="5" />
    </Style>

    <Style Selector="Border.panel-card">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#D8E2F2" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Margin" Value="0,4,0,6" />
    </Style>
  </Application.Styles>
</Application>
